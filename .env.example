# Supabase — copy to .env.local and fill from Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
#
# Run migrations in the SQL Editor (or Supabase CLI), in order:
# - supabase/migrations/20260329120000_posts.sql
# - supabase/migrations/20260329140000_posts_cover_slug.sql (optional if you run the next file)
# - supabase/migrations/20260330120000_news_media.sql  ← columns + post_images + video_url
# - supabase/migrations/20260330130000_post_videos.sql   ← many videos per post (post_videos)
# - supabase/migrations/20260330140000_admin_rls.sql     ← admin_users + RLS για /admin
# - supabase/migrations/20260330150000_storage_post_media.sql ← bucket post-media + ανέβασμα εικόνων
#
# Admin (/admin/login):
# 1) Authentication → Users → δημιούργησε χρήστη (email + password)
# 2) SQL Editor: insert into public.admin_users (user_id) values ('<uuid του χρήστη>');
#
# Optional dummy data: supabase/seed_dummy_posts.sql (SQL Editor, after migrations)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
